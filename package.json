{
  "name": "medusa-payment-nmi",
  "version": "0.4.0",
  "description": "Medusa v2 payment provider plugin for the NMI Gateway — card + ACH/eCheck + Apple/Google Pay via the NmiPayments tokenization component",
  "license": "MIT",
  "author": "Kael Broersma",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kaelbroersma/medusa-payment-nmi.git"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "medusa-plugin-payment",
    "medusa-plugin-integration",
    "payment",
    "payment-provider",
    "nmi",
    "collect.js",
    "card",
    "ach",
    "echeck",
    "hosted-fields"
  ],
  "files": [
    ".medusa/server",
    "storefront",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": "./.medusa/server/src/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.5.0 <3"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.17.1",
    "@medusajs/cli": "2.17.1",
    "@medusajs/framework": "2.17.1",
    "@medusajs/icons": "^2.17.1",
    "@medusajs/js-sdk": "^2.17.1",
    "@medusajs/medusa": "2.17.1",
    "@medusajs/ui": "^4.1.18",
    "@swc/core": "^1.7.28",
    "@tanstack/react-query": "^5.64.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
